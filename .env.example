# GTO-GameFlow v5.5 — 环境变量配置
# 复制此文件为 .env 并修改实际值:
#   cp .env.example .env

# ── 数据库 (PostgreSQL) ──────────────────────────────────────
# 格式: postgresql://用户:密码@主机:端口/数据库
GTO_DB_URL=postgresql://gto:gto_gameflow_2026@localhost:5432/gto_gameflow

# ── 告警通知 (QQ邮箱) ────────────────────────────────────────
GTO_ALERT_EMAIL_SENDER=739252249@qq.com
GTO_ALERT_EMAIL_AUTH_CODE=
GTO_ALERT_EMAIL_RECIPIENTS=739252249@qq.com

# ── API 密钥 ─────────────────────────────────────────────────
# API-Football (https://www.api-football.com/)
API_FOOTBALL_KEY=

# Football-Data.org (https://www.football-data.org/)
FOOTBALL_DATA_KEY=

# ── 日志 ─────────────────────────────────────────────────────
GTO_LOG_LEVEL=INFO
GTO_LOG_DIR=logs

# ── 回测 ─────────────────────────────────────────────────────
GTO_BACKTEST_SEASONS=2023/24,2024/25
GTO_BACKTEST_INITIAL_BANKROLL=50000

# ── 系统 ─────────────────────────────────────────────────────
GTO_VERSION=5.5.0
GTO_DB_PASSWORD=gto_gameflow_2026